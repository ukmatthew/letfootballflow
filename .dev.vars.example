# Copy to `.dev.vars` for local development with `wrangler dev`.
# `.dev.vars` is gitignored. These are the server-side secrets.

# Mixed into the anonymous voter-cookie hash. Use any long random string.
VOTER_HASH_SECRET="change-me-to-a-long-random-string"

# Cloudflare Turnstile secret key (optional locally).
# Turnstile "always passes" test secret:
# TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# Set to "1" to require Turnstile verification on votes.
TURNSTILE_REQUIRED="0"
