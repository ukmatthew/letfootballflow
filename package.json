{
  "name": "let-football-flow",
  "version": "1.0.0",
  "description": "Let Football Flow — a mobile-first fan vote on mandatory hydration breaks in football.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:ui": "vite",
    "build": "tsc -b && vite build",
    "build:worker": "wrangler pages functions build --outdir=./dist/worker/",
    "preview": "npm run build && npm run build:worker && wrangler dev --port 8788 --ip 127.0.0.1",
    "typecheck": "tsc -b --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply lff_db --local",
    "db:seed:local": "node scripts/seed-local-votes.mjs",
    "db:migrate:remote": "wrangler d1 migrations apply lff_db --remote",
    "deploy": "npm run build && npm run build:worker && wrangler deploy"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "wrangler": "^3.63.0"
  }
}
